# Frontend runs on Cloudflare Pages, backend still runs locally through a tunnel
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=https://<your-pages-project>.pages.dev
MAX_UPLOAD_MB=500
DEFAULT_MODEL_SIZE=small
WORKDIR_ROOT=./backend/workdir
ASR_MODEL_ROOT=./backend/models
FONTSIZE_RATIO=0.032
FONTSIZE_MIN=14
FONTSIZE_MAX=40
MARGINV_RATIO=0.035
MARGINV_MIN=14
MARGINV_MAX=52
SUBTITLE_FONT_NAME=Noto Sans CJK SC
VITE_API_BASE_URL=/api
BACKEND_ORIGIN=https://<your-tunnel-host>/api
